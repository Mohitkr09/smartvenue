{
  "expo": {
    "name": "SmartVenue",
    "slug": "client-app",
    "version": "1.0.0",
    "orientation": "portrait",

    "icon": "./assets/images/smartvenue_icon.png",
    "scheme": "clientapp",
    "userInterfaceStyle": "automatic",

    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.mohitkr.clientapp",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "SmartVenue uses your location to guide you to the best gate during events."
      }
    },

    "android": {
      "package": "com.mohitkr.clientapp",

      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "INTERNET"
      ],

      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#3b82f6"
      },

      "edgeToEdgeEnabled": true
    },

    "web": {
      "output": "static",
      "favicon": "./assets/images/smartvenue_icon.png"
    },

    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow location access for smart navigation and event guidance"
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash.png",
          "resizeMode": "contain",
          "backgroundColor": "#3b82f6"
        }
      ]
    ],

    "experiments": {
      "typedRoutes": true
    },

    "extra": {
      "eas": {
        "projectId": "5c9868e6-c9f0-4b9c-8f00-bbc4a782088f"
      }
    },

    "owner": "mohit-kr"
  }
}